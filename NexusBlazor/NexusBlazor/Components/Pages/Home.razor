@page "/"
@using System.ComponentModel
@inject Manager manager
@inject LoginInformation LoginInfo
@inject SqliteLogger Logger
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>nexus by iamJohnnySam</PageTitle>
<section class="hero" id="home">
    <h1>Welcome to nɛxus</h1>
</section>

<AuthorizeView>
    <Authorized>
        <section class="projects" id="projects">
            @if (!_initialized)
            {
                <div class="project-card">
                    <div class="project-title">Loading Projects...</div>
                    <div class="project-desc">Please wait...</div>
                </div>
            }
            else if (manager.ProjectDB.AllItems.Count == 0)
            {
                <div class="project-card">
                    <div class="project-title">NO PROJECTS AVAILABLE</div>
                    <div class="project-desc">...</div>
                </div>
            }
            else
            {
                @foreach (var project in manager.ProjectDB.AllItems)
                {
                    <ProjectCard ThisProject=project />
                }
            }
        </section>
    </Authorized>
</AuthorizeView>

@code {
    private bool _initialized = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Logger.Info("Home Screen Loading", interaction: "Program startup");
            
            await manager.EnsureInitializedAsync();
            manager.ProjectDB.PropertyChanged += OnProjectsChanged;
            
            _initialized = true;
            Logger.Info("Home Screen Loaded", interaction: "Program startup");
        }
        catch (Exception ex)
        {
            Logger.Error($"Failed to initialize Home page: {ex.Message}");
        }
    }

    private void OnProjectsChanged(object? sender, PropertyChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        manager.ProjectDB.PropertyChanged -= OnProjectsChanged;
    }
}